# AI Trading Skill environment variables
#
# Copy this file to .env for local development and fill in real values there.
# Keep .env private. It is ignored by git and should not be committed.

# -----------------------------------------------------------------------------
# Market data: Binance
# -----------------------------------------------------------------------------

# Binance REST base URL used for public candle data.
# Default: https://api.binance.com
BINANCE_BASE_URL=https://api.binance.com

# Binance API credentials.
# Not required for public OHLCV candle requests.
# Required later for signed/private endpoints such as account data, user streams,
# order management, or live trading.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# -----------------------------------------------------------------------------
# Market data: optional third-party providers
# -----------------------------------------------------------------------------

# CoinGecko API key.
# Required for CoinGecko Pro endpoints and higher rate limits.
COINGECKO_API_KEY=

# CoinPaprika API key.
# Optional for free public endpoints; use for paid plans, higher limits, or
# advanced/enterprise data access.
COINPAPRIKA_API_KEY=

# -----------------------------------------------------------------------------
# BNB Chain / on-chain data
# -----------------------------------------------------------------------------

# BNB Chain RPC endpoint for on-chain reads, wallet balances, contract calls,
# or event/log queries.
BNB_RPC_URL=

# Etherscan API V2 key for explorer lookups such as contract metadata,
# transactions, and verified source data on supported EVM chains.
# BNB Smart Chain uses chainid=56 in Etherscan API V2.
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------

# Telegram bot token from BotFather. Required only when sending Telegram notifications.
TELEGRAM_BOT_TOKEN=

# Telegram chat ID where notification messages should be delivered.
# Required only when sending Telegram notifications.
TELEGRAM_CHAT_ID=

# Discord incoming webhook URL. Required only when sending Discord notifications.
DISCORD_WEBHOOK_URL=
